{
  "version": 1,
  "generated_from": "front-matter of each doc; regenerate when front-matter changes",
  "doc_root": "docs/architecture/v2",
  "index_page": "README.md",
  "usage": {
    "for_codegen": "实现某模块时：先读 always_read，再读该模块自身（优先 compact，无则 README.md），再按 depends_on 仅读被引用到的相关章节。不要读其它无关模块。代码落地到该模块的 code_paths；并根据 lane 判断能否并行，根据 artifacts_dir 写模块产物。",
    "compact_field": "compact 为该文档的精简版规格路径；为 null 表示尚未生成，应回退读 path（全文）。",
    "testing_note": "testing 是所有模块的通用下游，常规代码生成无需全文读取，仅在补测试/场景矩阵时读取。",
    "lane_note": "多 Chat 并行看 lane；同一 lane 共享 code surface，必须串行。",
    "artifact_note": "模块 Chat 统一在 artifacts_dir 输出 bootstrap/handoff/manifest/checklist/audit。"
  },
  "orchestrator_rules": {
    "scope": "single-module-per-chat",
    "read_only_inputs": [
      "docs/architecture/v2/index.json",
      "docs/architecture/v2/codegen-progress.md",
      "{module.compact}"
    ],
    "forbidden_reads": [
      "docs/architecture/v2/codegen-progress.audit.md",
      "{module.artifacts_dir}/audit.log.md",
      "{module.artifacts_dir}/handoff.full.md",
      "git diff"
    ],
    "summary_max_lines": 10,
    "artifacts_subdir": "artifacts"
  },
  "integration_points": {
    "backend_admin_router": "services/admin-api/internal/transport/httpserver/admin_wiring.go",
    "frontend_routes": "apps/admin-web/src/router/routes.ts"
  },
  "always_read": [
    "common",
    "structure",
    "conventions"
  ],
  "parallel_lanes": [
    {
      "id": "platform-surface",
      "description": "平台与后台鉴权相关 surface，通常单模块串行推进。",
      "serial_order": [
        "auth"
      ],
      "modules": [
        "auth"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/transport/http/admin",
        "apps/admin-web/src/views/login",
        "apps/admin-web/src/views/system"
      ],
      "integration_points": [
        "backend_admin_router",
        "frontend_routes"
      ]
    },
    {
      "id": "games-surface",
      "description": "共享 games transport 与 views/games 的模块串行队列。",
      "serial_order": [
        "game",
        "account-auth",
        "product"
      ],
      "modules": [
        "game",
        "account-auth",
        "product"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/transport/http/games",
        "apps/admin-web/src/views/games"
      ],
      "integration_points": [
        "backend_admin_router",
        "frontend_routes"
      ]
    },
    {
      "id": "channels-surface",
      "description": "共享 channel domain / channels transport / views/channels 的模块串行队列。",
      "serial_order": [
        "channel",
        "channel-login",
        "feature-plugin"
      ],
      "modules": [
        "channel",
        "channel-login",
        "feature-plugin"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/domain/channel",
        "services/admin-api/internal/transport/http/channels",
        "apps/admin-web/src/views/channels"
      ],
      "integration_points": [
        "backend_admin_router",
        "frontend_routes"
      ]
    },
    {
      "id": "cashier-surface",
      "description": "共享 cashier domain / transport / views 的模块串行队列。",
      "serial_order": [
        "cashier-template",
        "game-cashier"
      ],
      "modules": [
        "cashier-template",
        "game-cashier"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/domain/cashier",
        "services/admin-api/internal/transport/http/cashier",
        "apps/admin-web/src/views/cashier"
      ],
      "integration_points": [
        "backend_admin_router",
        "frontend_routes"
      ]
    },
    {
      "id": "payment-surface",
      "description": "支付路由与支付页面的独立 surface。",
      "serial_order": [
        "payment"
      ],
      "modules": [
        "payment"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/domain/payment",
        "apps/admin-web/src/views/payment"
      ],
      "integration_points": [
        "frontend_routes"
      ]
    },
    {
      "id": "runtime-surface",
      "description": "运行时配置与同步相关 surface，必须 snapshot 在前、sync 在后。",
      "serial_order": [
        "snapshot",
        "sync"
      ],
      "modules": [
        "snapshot",
        "sync"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/domain/snapshot",
        "services/admin-api/internal/domain/sync",
        "services/admin-api/internal/transport/http/sync"
      ],
      "integration_points": [
        "backend_admin_router"
      ]
    },
    {
      "id": "audit-surface",
      "description": "审计 middleware 与审计页面相关 surface。",
      "serial_order": [
        "audit"
      ],
      "modules": [
        "audit"
      ],
      "shared_surfaces": [
        "services/admin-api/internal/transport/http/middleware",
        "apps/admin-web/src/views/audit"
      ],
      "integration_points": [
        "frontend_routes"
      ]
    },
    {
      "id": "dashboard-surface",
      "description": "Dashboard 只读聚合页面 surface。",
      "serial_order": [
        "dashboard"
      ],
      "modules": [
        "dashboard"
      ],
      "shared_surfaces": [
        "apps/admin-web/src/views/dashboard"
      ],
      "integration_points": [
        "frontend_routes"
      ]
    }
  ],
